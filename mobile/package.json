{
  "name": "sfluv-wallet-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "./scripts/with-local-env.sh expo start",
    "start:dev-client": "./scripts/with-local-env.sh expo start --dev-client",
    "android": "./scripts/with-local-env.sh expo start --android",
    "ios": "./scripts/with-local-env.sh expo start --ios",
    "prebuild:ios": "./scripts/with-local-env.sh expo prebuild --platform ios --no-install",
    "config:check": "./scripts/with-local-env.sh expo config --type public",
    "build:ios:dev": "./scripts/with-local-env.sh npx eas-cli build --platform ios --profile development",
    "build:android:dev": "./scripts/with-local-env.sh npx eas-cli build --platform android --profile development",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@expo/vector-icons": "^15.1.1",
    "@privy-io/expo": "^0.63.6",
    "@privy-io/expo-native-extensions": "^0.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "buffer": "^6.0.3",
    "ethers": "^5.7.2",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.7",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "fast-text-encoding": "^1.0.6",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.20.1",
    "react-native-passkeys": "^0.3.3",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
